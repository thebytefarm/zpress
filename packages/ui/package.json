{
  "name": "@zpress/ui",
  "version": "1.0.0-rc.0",
  "description": "Rspress plugin, theme components, and styles for zpress",
  "keywords": [
    "react",
    "rspress",
    "theme",
    "ui",
    "zpress"
  ],
  "homepage": "https://github.com/joggrdocs/zpress/tree/main/packages/ui#readme",
  "bugs": "https://github.com/joggrdocs/zpress/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist",
    "src/theme"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.mjs"
    },
    "./theme": {
      "types": "./src/theme/index.tsx",
      "import": "./src/theme/index.tsx"
    },
    "./icons": {
      "types": "./src/theme/icons/index.ts",
      "import": "./src/theme/icons/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "postbuild": "node scripts/generate-theme-css.mjs && oxfmt --write src/theme/styles/themes src/head/css/themes && node scripts/minify-head.mjs",
    "dev": "rslib build --watch --no-clean",
    "generate:theme-css": "node scripts/generate-theme-css.mjs",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@iconify-json/catppuccin": "^1.2.17",
    "@iconify-json/devicon": "^1.2.62",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/material-icon-theme": "^1.2.58",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/pixelarticons": "^1.2.4",
    "@iconify-json/simple-icons": "^1.2.77",
    "@iconify-json/skill-icons": "^1.2.4",
    "@iconify-json/vscode-icons": "^1.2.45",
    "@iconify/react": "^6.0.2",
    "@zpress/config": "workspace:*",
    "@zpress/theme": "workspace:*",
    "katex": "^0.16.45",
    "massaman": "^0.2.0",
    "mermaid": "^10.9.5",
    "openapi-sampler": "^1.7.2",
    "react-aria-components": "^1.17.0",
    "ts-morph": "^27.0.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@rslib/core": "catalog:",
    "@rspress/core": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "geist": "^1.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rspress-plugin-devkit": "^1.0.0",
    "rspress-plugin-file-tree": "^1.0.5",
    "rspress-plugin-katex": "^1.0.1",
    "rspress-plugin-supersub": "^1.0.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@rspress/core": "catalog:",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
