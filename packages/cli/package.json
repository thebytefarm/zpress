{
  "name": "@zpress/cli",
  "version": "1.0.0-rc.0",
  "description": "CLI for building and serving zpress documentation sites",
  "keywords": [
    "cli",
    "docs",
    "rspress",
    "zpress"
  ],
  "homepage": "https://github.com/joggrdocs/zpress/tree/main/packages/cli#readme",
  "bugs": "https://github.com/joggrdocs/zpress/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "packages/cli"
  },
  "bin": {
    "zpress": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "kidd build",
    "dev": "kidd dev",
    "stories": "kidd stories",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@clack/prompts": "^1.4.0",
    "@kidd-cli/core": "^0.24.0",
    "@rspress/core": "catalog:",
    "@zpress/config": "workspace:*",
    "@zpress/templates": "workspace:*",
    "@zpress/theme": "workspace:*",
    "@zpress/ui": "workspace:*",
    "fast-glob": "^3.3.3",
    "get-port": "^7.2.0",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.3",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "jiti": "^2.7.0",
    "liquidjs": "^10.27.0",
    "massaman": "^0.2.0",
    "react": "^19.2.6",
    "yaml": "^2.9.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kidd-cli/cli": "^0.11.9",
    "@types/react": "^19.2.15",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
