{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "generate:schema": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "scripts/generate-schema.ts"],
      "outputs": ["schemas/**"]
    },
    "build": {
      "dependsOn": ["generate:schema", "^build"],
      "inputs": ["src/**", "rslib.config.ts", "package.json"],
      "outputs": ["dist/**"]
    }
  }
}
