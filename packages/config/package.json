{
  "name": "@zpress/config",
  "version": "1.0.0-rc.1",
  "description": "Configuration loading and validation for zpress",
  "keywords": [
    "config",
    "schema",
    "validation",
    "zpress"
  ],
  "homepage": "https://github.com/joggrdocs/zpress/tree/main/packages/config#readme",
  "bugs": "https://github.com/joggrdocs/zpress/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "packages/config"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.mjs"
    },
    "./schema": {
      "default": "./schemas/schema.json"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch --no-clean",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "generate:schema": "tsx scripts/generate-schema.ts"
  },
  "dependencies": {
    "@zpress/theme": "workspace:*",
    "c12": "4.0.0-beta.5",
    "massaman": "^0.2.0",
    "type-fest": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rslib/core": "catalog:",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "tsx": "^4.22.3",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependencies": {
    "react": "^19.2.5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
