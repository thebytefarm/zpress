{
  "name": "@zpress/kit",
  "version": "0.2.23",
  "description": "Documentation framework powered by Rspress with a config-driven information architecture",
  "keywords": [
    "docs",
    "documentation",
    "rspress",
    "zpress"
  ],
  "homepage": "https://github.com/joggrdocs/zpress/tree/main/packages/zpress#readme",
  "bugs": "https://github.com/joggrdocs/zpress/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "packages/zpress"
  },
  "bin": {
    "zpress": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch --no-clean",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@zpress/cli": "workspace:*",
    "@zpress/config": "workspace:*",
    "@zpress/core": "workspace:*",
    "@zpress/ui": "workspace:*"
  },
  "devDependencies": {
    "@rslib/core": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@rspress/core": "catalog:",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
