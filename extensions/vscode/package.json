{
  "name": "zpress-vscode",
  "displayName": "zpress",
  "version": "0.2.2",
  "private": true,
  "description": "Run zpress dev server and preview documentation from VS Code",
  "categories": [
    "Other"
  ],
  "homepage": "https://zpress.dev",
  "bugs": {
    "url": "https://github.com/joggrdocs/zpress/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "extensions/vscode"
  },
  "publisher": "joggr",
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-git-tag-version",
    "publish": "vsce publish --no-git-tag-version"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "catalog:"
  },
  "contributes": {
    "commands": [
      {
        "command": "zpress.start",
        "title": "zpress: Start Server",
        "icon": "$(debug-start)"
      },
      {
        "command": "zpress.stop",
        "title": "zpress: Stop Server",
        "icon": "$(debug-stop)"
      },
      {
        "command": "zpress.toggle",
        "title": "zpress: Toggle Server"
      },
      {
        "command": "zpress.preview",
        "title": "zpress: Preview Page",
        "icon": "$(globe)"
      },
      {
        "command": "zpress.openPage",
        "title": "zpress: Open Page"
      },
      {
        "command": "zpress.restart",
        "title": "zpress: Restart Server"
      },
      {
        "command": "zpress.openInBrowser",
        "title": "zpress: Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "zpress.collapseAll",
        "title": "Collapse All",
        "icon": "$(collapse-all)"
      },
      {
        "command": "zpress.editSource",
        "title": "Edit Source",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "zpress.preview",
          "when": "resourceLangId == markdown && zpress:isTrackedFile && zpress:serverReady",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "zpress.editSource",
          "when": "viewItem == zpressLeaf",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "zpress.collapseAll",
          "when": "view == zpress.server && zpress:serverReady",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zpress",
          "title": "zpress",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "zpress.loading",
        "contents": "$(sync~spin) Building docs site...",
        "when": "zpress:serverStarting"
      },
      {
        "view": "zpress.loading",
        "contents": "$(book) Preview your docs site right here.\n[Start Server](command:zpress.start)",
        "when": "zpress:serverStopped"
      }
    ],
    "configuration": {
      "title": "zpress",
      "properties": {
        "zpress.server.autoOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the docs site in the browser when the dev server starts."
        },
        "zpress.server.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the dev server when the zpress sidebar is opened."
        },
        "zpress.server.port": {
          "type": "number",
          "default": 6174,
          "description": "Port for the dev server."
        },
        "zpress.theme": {
          "type": "string",
          "enum": [
            "base",
            "midnight",
            "arcade"
          ],
          "default": null,
          "markdownDescription": "Override the theme used for the docs preview. When set, this overrides the `theme.name` in your `zpress.config` without modifying the config file."
        },
        "zpress.theme.mode": {
          "type": "string",
          "enum": [
            "dark",
            "light",
            "toggle"
          ],
          "default": null,
          "markdownDescription": "Override the color mode for the docs preview. When set, this overrides the `theme.colorMode` in your `zpress.config` without modifying the config file."
        }
      }
    },
    "views": {
      "zpress": [
        {
          "id": "zpress.loading",
          "name": "zpress",
          "when": "zpress:isProject && !zpress:serverReady"
        },
        {
          "id": "zpress.pages",
          "name": "Pages",
          "when": "zpress:section.pages && zpress:serverReady",
          "visibility": "visible"
        },
        {
          "id": "zpress.apps",
          "name": "Apps",
          "when": "zpress:section.apps && zpress:serverReady",
          "visibility": "visible"
        },
        {
          "id": "zpress.packages",
          "name": "Packages",
          "when": "zpress:section.packages && zpress:serverReady",
          "visibility": "visible"
        },
        {
          "id": "zpress.workspaces",
          "name": "Workspaces",
          "when": "zpress:section.workspaces && zpress:serverReady",
          "visibility": "visible"
        },
        {
          "id": "zpress.server",
          "name": "Server",
          "when": "zpress:isProject && zpress:serverReady",
          "visibility": "visible"
        }
      ]
    }
  },
  "activationEvents": [
    "workspaceContains:zpress.config.js",
    "workspaceContains:zpress.config.json",
    "workspaceContains:zpress.config.mjs",
    "workspaceContains:zpress.config.mts",
    "workspaceContains:zpress.config.ts"
  ],
  "extensionKind": [
    "workspace"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.115.0"
  }
}
